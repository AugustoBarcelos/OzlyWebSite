# ============================================================================
# Ozly Public Site (ozly.au) — environment variables
# Vite só expõe variáveis prefixadas com VITE_. São injetadas no client em
# build time — NUNCA colocar chave de service role aqui. ANON key é segura
# por design (RLS faz o gating).
#
# Local dev: copie pra .env.local (já gitignorado) e preencha.
# Prod (Cloudflare Pages): configurar em Settings → Environment variables.
# ============================================================================

# Supabase — mesmo projeto do admin-portal e do app mobile.
# Pegar em: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://jnhwgwnphlnhjlgygjql.supabase.co
VITE_SUPABASE_ANON_KEY=

# Stores públicas — usados na landing /v/:code
VITE_APP_STORE_URL=https://apps.apple.com/au/app/ozly/id6760398649
VITE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.augusto.ozly
