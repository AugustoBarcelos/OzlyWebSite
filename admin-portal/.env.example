# ============================================================================
# Ozly Admin Portal — environment variables
# DO NOT COMMIT REAL VALUES. Set these in Cloudflare Pages env vars.
# Locally, copy this file to .env.local (gitignored) and fill values.
# ============================================================================

# Supabase (anon key only — service role JAMAIS aqui, ver BRIEFING § 7-L7)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# PostHog Cloud EU — projeto SEPARADO do app mobile (admin telemetry only)
VITE_POSTHOG_API_KEY=
VITE_POSTHOG_HOST=https://eu.posthog.com

# Sentry — DSN do projeto admin-portal (separado do mobile)
VITE_SENTRY_DSN=

# ----------------------------------------------------------------------------
# Sentry REST API (OPTIONAL) — enables in-portal data on the /errors page.
# Without these, /errors falls back to quick-link cards into sentry.io.
#
# 1) Create a Personal Auth Token at:
#       https://sentry.io/settings/account/api/auth-tokens/
#    Required scopes: org:read, project:read, event:read
# 2) Find the org and project slugs in any Sentry URL
#    (e.g. https://<ORG>.sentry.io/projects/<PROJECT>/).
# 3) Paste the values below. The token is exposed at build time, but the admin
#    portal is admin-only auth-gated and the token only carries read scopes.
# ----------------------------------------------------------------------------
VITE_SENTRY_API_TOKEN=
VITE_SENTRY_ORG=
VITE_SENTRY_PROJECT=

# Optional: override the public URL of this app (used to build the magic-link
# redirect target). Leave blank locally — falls back to window.location.origin.
# Set in Cloudflare Pages env vars to e.g. https://peixes.ozly.au if needed.
VITE_APP_URL=
