# Org Portal — public (client-shipped) env. Anon key ONLY; never the service role.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Base URL used to build shareable invite links (https://ozly.app/invite/{token}).
VITE_INVITE_BASE_URL=https://ozly.app

# ── Edge Function secrets (server-side ONLY — never VITE_, never shipped to the
#    browser). Set with: supabase secrets set ANTHROPIC_API_KEY=... ───────────
#
# Used by the `import-map` Edge Function (AI-assisted job import). If
# ANTHROPIC_API_KEY is unset the function returns 503 and the Import page falls
# back to a manual column-mapping UI, so AI is optional.
#   ANTHROPIC_API_KEY  — Anthropic API key (required for the AI mapping step).
#   ANTHROPIC_MODEL    — optional; defaults to "claude-sonnet-4-6".
