# Cloudflare Pages SPA fallback.
# Without this, dynamic routes like /v/:code, /me/:code, /me/auth?t=... 404
# because Cloudflare doesn't find a static file at that path. The 200 status
# code makes this a REWRITE (not a redirect) — the URL stays as is and the
# client-side React Router resolves the route.
#
# Static files in /dist/ still take precedence over this fallback (Cloudflare
# Pages checks for the file first, only falls back when missing). So
# /guide/index.html, /support/index.html, /OSLY.svg, etc keep working as before.

/v/*       /index.html  200
/me/auth   /index.html  200
/me/*      /index.html  200
/r/*       /index.html  200
/refer     /index.html  200
